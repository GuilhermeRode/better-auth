    "drizzle-orm": "^0.38.4",
    "next": "^15.0.0",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "drizzle-kit": "^0.30.0",
